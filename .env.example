# ── Rutas de trabajo ──────────────────────────────────────────────────────────
JOBS_DIR=jobs
DOWNLOADS_DIR=descargas_sharepoint

# ── Descarga SharePoint ───────────────────────────────────────────────────────
MAX_WORKERS_LISTADO=8
MAX_WORKERS_DESCARGA=12

# ── Validación ────────────────────────────────────────────────────────────────
CHECKLIST_LOTE_GUARDADO=50
TIMEOUT_DESCARGA=300

# ── Análisis IA (OpenAI) ──────────────────────────────────────────────────────
IA_HABILITADO=false
OPENAI_API_KEY=TU_API_KEY_AQUI
OPENAI_MODEL=gpt-4o

# Páginas máximas por documento enviadas a la IA (primeras N/2 + últimas N/2)
IA_MAX_PAGINAS_COMPROMISO=10
IA_MAX_PAGINAS_VISITA=15
IA_MAX_PAGINAS_TRATAMIENTO=10
IA_DPI=200
IA_TIMEOUT=120

# ── Búsqueda web adicional (estudio de mercado carpeta 04) ────────────────────
# SerpAPI: fuente principal de URLs para tiendas colombianas (Google Shopping).
#   Registro y clave gratuita en https://serpapi.com/
#   Con clave configurada: mejora drásticamente la tasa de capturas exitosas.
SERPAPI_KEY=

# Brave Search: fuente adicional recomendada (mejor cuota que CSE).
#   Plan gratuito: 2.000 consultas/mes. Registro en https://api.search.brave.com/
#   App → "Subscriptions" → plan Free → copiar el "Subscription Token".
BRAVE_API_KEY=

# Google Custom Search: respaldo opcional (cuota gratis baja: 100 consultas/día).
#   1. Clave de API: https://console.cloud.google.com/ → Custom Search JSON API
#   2. Motor CSE: https://programmablesearch.google.com/ → copiar el ID (cx)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=