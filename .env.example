# ── Rutas de trabajo ──────────────────────────────────────────────────────────
JOBS_DIR=jobs
DOWNLOADS_DIR=descargas_sharepoint

# ── Descarga SharePoint ───────────────────────────────────────────────────────
MAX_WORKERS_LISTADO=8
MAX_WORKERS_DESCARGA=12

# ── Validación ────────────────────────────────────────────────────────────────
CHECKLIST_LOTE_GUARDADO=50
TIMEOUT_DESCARGA=300

# ── Análisis IA (OpenAI) ──────────────────────────────────────────────────────
IA_HABILITADO=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Páginas máximas por documento enviadas a la IA (primeras N/2 + últimas N/2)
IA_MAX_PAGINAS_COMPROMISO=10
IA_MAX_PAGINAS_VISITA=15
IA_MAX_PAGINAS_TRATAMIENTO=10
IA_DPI=200
IA_TIMEOUT=120
